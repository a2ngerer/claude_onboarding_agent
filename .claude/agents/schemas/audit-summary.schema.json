{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-onboarding-agent/schemas/audit-summary.schema.json",
  "title": "audit-summary",
  "description": "Envelope returned by the audit-collector subagent.",
  "type": "object",
  "required": ["ok", "kind", "data"],
  "additionalProperties": false,
  "properties": {
    "ok": { "type": "boolean" },
    "kind": { "const": "audit-summary" },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "data": {
      "type": "object",
      "required": ["total", "high", "medium", "low", "top_titles"],
      "additionalProperties": false,
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "high": { "type": "integer", "minimum": 0 },
        "medium": { "type": "integer", "minimum": 0 },
        "low": { "type": "integer", "minimum": 0 },
        "top_titles": {
          "type": "array",
          "maxItems": 5,
          "items": { "type": "string" }
        },
        "error": {
          "type": "string",
          "description": "Optional short reason when ok=false or the audit skill could not run."
        }
      }
    }
  }
}
