{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-onboarding-agent/schemas/upgrade-plan.schema.json",
  "title": "upgrade-plan",
  "description": "Envelope returned by the upgrade-planner subagent.",
  "type": "object",
  "required": ["ok", "kind", "data"],
  "additionalProperties": false,
  "properties": {
    "ok": { "type": "boolean" },
    "kind": { "const": "upgrade-plan" },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "data": {
      "type": "object",
      "required": ["version", "proposed_changes", "summary"],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "string" },
        "proposed_changes": {
          "type": "array",
          "maxItems": 50,
          "items": {
            "type": "object",
            "required": ["change_id", "setup_type", "file", "section", "rationale", "diff"],
            "additionalProperties": false,
            "properties": {
              "change_id": { "type": "string" },
              "setup_type": { "type": "string" },
              "file": { "type": "string" },
              "section": { "type": "string" },
              "rationale": { "type": "string" },
              "diff": { "type": "string" }
            }
          }
        },
        "summary": {
          "type": "object",
          "required": ["total_sections_examined", "total_changes", "files_with_changes"],
          "additionalProperties": true,
          "properties": {
            "total_sections_examined": { "type": "integer", "minimum": 0 },
            "total_changes": { "type": "integer", "minimum": 0 },
            "files_with_changes": {
              "type": "array",
              "items": { "type": "string" }
            },
            "truncated": { "type": "boolean" },
            "missing_templates": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
